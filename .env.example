# ===========================================
# Kurisu 环境变量配置
# ===========================================
# 复制此文件为 .env，填入你的 API Key
# .env 已在 .gitignore 中，不会提交到仓库

# ===========================================
# 模型 API 配置
# ===========================================

# GLM-5 (智谱 GLM via Anthropic 兼容 API)
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/anthropic

# Claude API (via AiCodeMirror 代理)
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.aicodemirror.com/api/claudecode

# MiniMax API
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic

# Zhipu Embedding (向量化专用，与 GLM-5 同一平台，可复用 ZHIPU_API_KEY)
ZHIPU_EMBEDDING_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/embeddings
ZHIPU_EMBEDDING_API_KEY=

# 可选：本地模型
OLLAMA_ENDPOINT=http://localhost:11434

# ===========================================
# 工具 / MCP 配置
# ===========================================

# GitHub MCP
GITHUB_PERSONAL_ACCESS_TOKEN=

# Tavily Search API (web-search skill 深度搜索)
# 获取地址: https://tavily.com/
TAVILY_API_KEY=

# ===========================================
# Channel 配置 (多平台接入)
# ===========================================

# Mock Channel (开发测试)
ENABLE_MOCK_CHANNEL=false

# Telegram Bot
# 从 @BotFather 获取
TELEGRAM_BOT_TOKEN=
# Webhook URL (可选，设置后会自动注册)
TELEGRAM_WEBHOOK_URL=

# QQ Bot (NapCat OneBot11)
# NapCat HTTP API 地址
NAPCAT_HTTP_URL=http://napcat:3001
# OneBot11 access_token (可选)
NAPCAT_ACCESS_TOKEN=
# Polling 间隔 (毫秒)
QQ_POLL_INTERVAL=1000

# ===========================================
# 系统配置
# ===========================================

# 日志级别
LOG_LEVEL=info
